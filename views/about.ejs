<%- include('partials/header') %>

<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-lg-8 text-center">
      <h1 class="display-4 fw-bold text-success mb-4">About ResumeForge AI</h1>
      <p class="lead mb-5">
        We built ResumeForge AI to help remote developers and tech professionals 
        around the world — especially in Nigeria and other emerging markets — 
        beat ATS filters, stand out to recruiters, and land more interviews faster.
      </p>

      <div class="row g-5 mt-5">
        <div class="col-md-6">
          <div class="card h-100 bg-dark border-0 shadow">
            <div class="card-body p-5 text-center">
              <i class="fas fa-rocket fa-3x text-success mb-4"></i>
              <h4 class="mb-3">Our Mission</h4>
              <p class="text-muted">
                To democratize access to world-class job application tools 
                using the latest AI — so anyone can compete for remote roles 
                on equal footing.
              </p>
            </div>
          </div>
        </div>

        <div class="col-md-6">
          <div class="card h-100 bg-dark border-0 shadow">
            <div class="card-body p-5 text-center">
              <i class="fas fa-users fa-3x text-success mb-4"></i>
              <h4 class="mb-3">Who We Help</h4>
              <p class="text-muted">
                Remote developers, freelancers, Nigerian tech talent, 
                career switchers — anyone applying to global remote-first companies.
              </p>
            </div>
          </div>
        </div>
      </div>

      <div class="mt-5 pt-5">
        <h3 class="fw-bold mb-4">Built with ❤️ in Nigeria</h3>
        <p class="text-muted">
          Created by developers, for developers.<br>
          We understand the struggle — irregular power, expensive data, fierce competition.<br>
          That's why we made this tool fast, free to start, and mobile-friendly.
        </p>
      </div>
    </div>
  </div>
</div>


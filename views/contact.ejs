<%- include('partials/header') %>

<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-lg-8 text-center">
      <h1 class="display-5 fw-bold text-success mb-4">Get in Touch</h1>
      <p class="lead mb-5">
        Have questions, feedback, or partnership ideas?<br>
        We'd love to hear from you.
      </p>

      <div class="card bg-dark border-0 shadow p-5">
        <div class="row g-4">
          <div class="col-md-6">
            <h4 class="mb-4">Email</h4>
            <p class="text-muted">
              <a href="mailto:hello@resumeforge.ai" class="text-success text-decoration-none">
                hello@resumeforge.ai
              </a>
            </p>
          </div>

          <div class="col-md-6">
            <h4 class="mb-4">X (Twitter)</h4>
            <p class="text-muted">
              <a href="https://x.com/ndaninfoassure" target="_blank" class="text-success text-decoration-none">
                @ndaninfoassure
              </a>
            </p>
          </div>
        </div>

        <div class="mt-5 pt-4 border-top border-secondary">
          <h4 class="mb-4">Send us a message</h4>
          <form id="contactForm">
            <div class="mb-3">
              <input type="text" class="form-control bg-secondary border-0 text-light" placeholder="Your Name">
            </div>
            <div class="mb-3">
              <input type="email" class="form-control bg-secondary border-0 text-light" placeholder="Your Email">
            </div>
            <div class="mb-4">
              <textarea class="form-control bg-secondary border-0 text-light" rows="5" placeholder="Your message..."></textarea>
            </div>
            <button type="submit" class="btn btn-success btn-lg w-100">
              Send Message
            </button>
          </form>
          <p class="text-muted mt-3 small">We'll get back to you within 24–48 hours.</p>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>